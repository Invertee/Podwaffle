{
  "name": "podwaffle-mobile",
  "version": "1.0.0",
  "description": "PodWaffle native mobile app powered by Capacitor",
  "scripts": {
    "setup": "npm install && npx cap sync",
    "sync": "npx cap sync",
    "android": "npx cap run android",
    "android:open": "npx cap open android",
    "ios": "npx cap run ios",
    "ios:open": "npx cap open ios",
    "update-server": "node scripts/set-server.js"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/ios": "^8.4.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@strasberry/capacitor-cast": "^1.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "typescript": "^5.0.0"
  }
}
