{
  "name": "podwaffle-mobile",
  "version": "1.0.0",
  "description": "PodWaffle native mobile app powered by Capacitor",
  "scripts": {
    "setup": "npm install && npx cap sync",
    "sync": "npx cap sync",
    "android": "npx cap run android",
    "android:open": "npx cap open android",
    "ios": "npx cap run ios",
    "ios:open": "npx cap open ios",
    "update-server": "node scripts/set-server.js"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/app": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@jofr/capacitor-media-session": "^4.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "typescript": "^5.0.0"
  }
}
